// Copy this file to Secrets.swift and fill in your values.
// Secrets.swift is gitignored and must NOT be committed.
import Foundation

enum Secrets {
    // API Gateway base URL (e.g. https://api.yourdomain.com)
    static let apiURL = "https://api.example.com"

    // API key retrieved from AWS Secrets Manager after `terraform apply`
    static let apiKey = "your-api-key-here"

    // GitHub Personal Access Token with repo read permissions
    static let githubToken = "ghp_your_token_here"

    // Comma-separated default repositories (owner/repo format)
    static let defaultRepos: [String] = [
        "owner/repo1",
        "owner/repo2",
    ]

    // Default sprint date range (ISO 8601 format)
    static let defaultSince = "2024-01-01T00:00:00Z"
    static let defaultUntil = "2024-01-14T00:00:00Z"

    // Default sprint name
    static let sprintName = "Sprint Analysis"

    // Expected workflow duration in milliseconds (used for progress animation)
    static let workflowDuration = 50000
}
